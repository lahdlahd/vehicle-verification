generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

enum VehicleStatus {
  clean
  minor_damage
  write_off
}

model Vehicle {
  id          String        @id @default(cuid())
  vin         String        @unique
  status      VehicleStatus
  description String
  createdAt   DateTime      @default(now())

  @@map("vehicles")
}